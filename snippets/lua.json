{
    "Defold script file template": {
        "prefix": "script",
        "body": [
            "---@class ${1:script}",
            "",
            "---@package",
            "---@param self ${1:script}",
            "function init(self)",
            "\t",
            "end",
            "",
            "---@package",
            "---@param self ${1:script}",
            "---@param dt number",
            "function update(self, dt)",
            "\t",
            "end",
            "",
            "---@package",
            "---@param self ${1:script}",
            "---@param message_id hash",
            "---@param message table",
            "---@param sender url",
            "function on_message(self, message_id, message, sender)",
            "\t",
            "end",
            "",
            "---@package",
            "---@param self ${1:script}",
            "---@param action_id hash",
            "---@param action on_input.action",
            "---@return boolean|nil",
            "function on_input(self, action_id, action)",
            "\t",
            "end",
            "",
            "---@package",
            "---@param self ${1:script}",
            "function final(self)",
            "\t",
            "end"
        ],
        "description": "Defold script file with annotated lifecycle methods"
    },
